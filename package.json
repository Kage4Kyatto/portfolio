{
  "name": "portfolio-fullstack-site",
  "version": "1.0.0",
  "description": "Five-page portfolio website with Node.js backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "install:react": "npm --prefix frontend/react-app install",
    "dev:react": "npm --prefix frontend/react-app run dev",
    "build:react": "npm --prefix frontend/react-app run build",
    "build:app": "npm run build:react",
    "preview:react": "npm --prefix frontend/react-app run preview",
    "install:fastify": "npm --prefix backend/fastify install",
    "dev:fastify": "npm --prefix backend/fastify run dev",
    "start:fastify": "npm --prefix backend/fastify run start",
    "lint": "node --check server.js && node --check backend/node/controllers/contactController.js && node --check backend/node/middleware/authMiddleware.js && node --check backend/node/routes/contactRoutes.js && node --check backend/node/routes/blogRoutes.js && node --check backend/node/services/notificationQueue.js && node --check backend/node/data/storage.js && node --check public/assets/js/core/main.js && node --check public/assets/js/pages/contact.js && node --check public/assets/js/pages/admin.js && node --check public/assets/js/pages/blog.js && node --check public/assets/js/pages/analytics.js && node --check tests/e2e/site.spec.js && node --check playwright.config.js",
    "test": "node --test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "quality": "npm run lint && npm test",
    "lighthouse": "lhci autorun --config=./lighthouserc.json",
    "typecheck": "tsc --noEmit",
    "build:ts": "tsc",
    "stats:messages": "node dist-tools/tools/ts/messageStats.js",
    "ts:site-report": "node dist-tools/tools/ts/siteReport.js",
    "ts:asset-report": "node dist-tools/tools/ts/assetReport.js",
    "python:report": "python scripts/python/message_report.py",
    "python:site-report": "python scripts/python/site_report.py",
    "python:message-health": "python scripts/python/message_health.py",
    "go:message-summary": "go run tools/go/message_summary.go",
    "rust:message-summary": "cargo run --manifest-path tools/rust/message_summary/Cargo.toml --",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "migrate:db": "node scripts/node/migrateDb.js",
    "setup": "node scripts/node/setupDev.js",
    "blog:new": "node scripts/node/createBlogPost.js",
    "docs": "swagger-jsdoc -d docs/swagger-config.js -o docs/swagger.json",
    "reset:contact-data": "node tools/resetContactData.js",
    "clean:contact-data": "git restore --worktree backend/php/data/messages.json backend/php/data/contact_rate_limits.json"
  },
  "keywords": [
    "portfolio",
    "express",
    "frontend",
    "backend"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "xss": "^1.0.14",
    "compression": "^1.7.4",
    "pg": "^8.13.1",
    "swagger-ui-express": "^5.0.0",
    "swagger-jsdoc": "^6.2.8",
    "@sentry/node": "^7.90.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@types/node": "^25.9.3",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.55.0",
    "nodemon": "^3.1.10",
    "wait-on": "^8.0.3",
    "supertest": "^7.1.1",
    "typescript": "^6.0.3"
  }
}
